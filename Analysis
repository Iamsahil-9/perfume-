Auto Stock Analysis Engine (India)\n# Requirements: pip install yfinance pandas pandas_ta requests beautifulsoup4\n\nimport yfinance as yf\nimport pandas as pd\nimport pandas_ta as ta\n\ndef analyze_stock(symbol):\n    stock = yf.Ticker(symbol)\n\n    info = stock.info\n    hist = stock.history(period="6mo")\n\n    # --- BASIC INFO ---\n    company_name = info.get('longName')\n    sector = info.get('sector')\n    cmp = info.get('currentPrice')\n    market_cap = info.get('marketCap')\n\n    # --- FUNDAMENTAL DATA ---\n    revenue_growth = info.get('revenueGrowth')\n    profit_growth = info.get('earningsGrowth')\n    debt = info.get('totalDebt')\n    roe = info.get('returnOnEquity')\n    roce = info.get('returnOnAssets')\n    promoter_holding = info.get('heldPercentInsiders')\n    institutional_holding = info.get('heldPercentInstitutions')\n\n    # --- TECHNICAL DATA ---\n    hist['RSI'] = ta.rsi(hist['Close'], length=14)\n    hist['MA20'] = ta.sma(hist['Close'], length=20)\n    hist['MA50'] = ta.sma(hist['Close'], length=50)\n\n    trend = "Uptrend" if hist['MA20'].iloc[-1] > hist['MA50'].iloc[-1] else "Downtrend"\n\n    support = hist['Low'].rolling(20).min().iloc[-1]\n    resistance = hist['High'].rolling(20).max().iloc[-1]\n    volume = hist['Volume'].iloc[-1]\n    rsi = hist['RSI'].iloc[-1]\n    moving_avg = hist['MA20'].iloc[-1]\n\n    # --- OUTPUT ---\n    result = {\n        "Company Name": company_name,\n        "Sector": sector,\n        "CMP": cmp,\n        "Market Cap": market_cap,\n\n        "Fundamental Analysis": {\n            "Revenue Growth": revenue_growth,\n            "Profit Growth": profit_growth,\n            "Debt": debt,\n            "ROE": roe,\n            "ROCE": roce,\n            "Promoter Holding": promoter_holding,\n            "Institutional Holding": institutional_holding,\n        },\n\n        "Technical Analysis": {\n            "Trend": trend,\n            "Support": support,\n            "Resistance": resistance,\n            "Volume": volume,\n            "RSI": rsi,\n            "Moving Average": moving_avg,\n        },\n    }\n\n    return result\n\n# Example Run\nif name == "main":\n    stock_symbol = "RELIANCE.NS"   # NSE symbol\n    data = analyze_stock(stock_symbol)\n\n    from pprint import pprint\n    pprint(data)
